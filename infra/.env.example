# infra/.env.example — operator environment variable template.
# Copy to infra/.env and fill in real values before starting the stack.
# NEVER commit .env — it must be in .gitignore.
#
# Referenced by: infra/docker-compose.prod.yml
# Design: docs/designs/0028-lightweight-query-engine-deployment.md §11.5

# -----------------------------------------------------------------------------
# REQUIRED: database credentials
# -----------------------------------------------------------------------------
# Use a strong random value: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION

# Optional overrides (defaults are sensible for a single-box deployment):
# POSTGRES_USER=mg_onchain
# POSTGRES_DB=mg_onchain

# -----------------------------------------------------------------------------
# OPTIONAL: OTLP observability
# -----------------------------------------------------------------------------
# Set to route traces to your collector (Jaeger, Grafana Tempo, Honeycomb, etc.).
# Leave unset to disable OTLP export (stdout tracing only).
# See PRODUCTION.md §6 for otel-collector setup.
# OTEL_ENDPOINT=http://otel-collector:4317

# -----------------------------------------------------------------------------
# OPTIONAL: image version pins
# -----------------------------------------------------------------------------
# SERVICE_TAG=0.1.0
# AGAVE_TAG=v3.1.13
# RETH_TAG=v1.3.0

# -----------------------------------------------------------------------------
# OPTIONAL: data directory overrides
# -----------------------------------------------------------------------------
# Map named volumes to dedicated NVMe mount points for production:
# RETH_DATA_DIR=/mnt/nvme/reth
# LIGHTHOUSE_DATA_DIR=/mnt/nvme/lighthouse
# AGAVE_LEDGER_DIR=/mnt/nvme/agave
# PG_DATA_DIR=/mnt/nvme/postgres

# -----------------------------------------------------------------------------
# OPTIONAL: runtime tuning
# -----------------------------------------------------------------------------
# RUST_LOG=info
# RETH_LOG_LEVEL=info
