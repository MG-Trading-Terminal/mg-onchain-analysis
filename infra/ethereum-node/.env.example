# Ethereum node stack — environment configuration
#
# Copy this file to .env and fill in the values for your deployment.
# Never commit the real .env file (it may contain paths sensitive to your setup).
# The jwt.hex file is also secret — see jwt-secret.example for the placeholder.
#
# ADR 0003: no Alchemy/Infura/QuickNode in production. This stack is self-hosted.
# ADR 0004: Reth (execution client) + Lighthouse (consensus client), Docker deployment.

# ---------------------------------------------------------------------------
# Data directories (must be on an NVMe volume — see README.md §2)
# ---------------------------------------------------------------------------

# Reth database directory.
# Minimum: 1.5 TB NVMe. Recommended: 2 TB NVMe.
# Growth: ~75 GB/month on a pruned mainnet node.
RETH_DATA_DIR=/data/reth

# Lighthouse beacon chain directory.
# Minimum: 100 GB. Recommended: 200 GB.
LIGHTHOUSE_DATA_DIR=/data/lighthouse

# ---------------------------------------------------------------------------
# JWT secret (Engine API authentication between Reth and Lighthouse)
# ---------------------------------------------------------------------------

# Path to the 64-char hex JWT secret file.
# Generate with: openssl rand -hex 32 > jwt.hex
# See jwt-secret.example for a placeholder showing the expected format.
# NEVER commit the real jwt.hex file.
JWT_SECRET_PATH=./jwt.hex

# ---------------------------------------------------------------------------
# Reth RPC ports
# ---------------------------------------------------------------------------

# HTTP JSON-RPC port (chain-adapter backfill queries).
# Bound to 127.0.0.1 by default — do not expose publicly without a reverse proxy.
RETH_HTTP_PORT=8545

# WebSocket JSON-RPC port (chain-adapter eth_subscribe live stream).
# Bound to 127.0.0.1 by default.
RETH_WS_PORT=8546

# Prometheus metrics scrape port.
# Bound to 127.0.0.1 by default.
RETH_METRICS_PORT=9001

# ---------------------------------------------------------------------------
# Reth logging
# ---------------------------------------------------------------------------

# Log verbosity: trace | debug | info | warn | error
# Use "info" in production. "debug" is useful during initial sync.
RETH_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Sync mode (informational — actual flag is set in docker-compose.yml command)
# ---------------------------------------------------------------------------

# Reth sync mode: snap sync (default, recommended per ADR 0004 Decision 2).
# Do NOT change to full sync from genesis — it takes days and is not needed
# for an analytics consumer. Set in docker-compose.yml, not here.
# RETH_SYNC_MODE=snap
